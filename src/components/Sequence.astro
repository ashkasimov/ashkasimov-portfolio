---
import type { Photo } from '../data/projects';

interface Props {
  photos: Photo[];
  title?: string;
  category?: string;
  year?: string;
  summary?: string;
}
const { photos, title, category, year, summary } = Astro.props;
---

<section class="hseq" aria-label="Project gallery">
  <div
    class="hseq__track"
    tabindex="0"
    role="region"
    aria-label="Image gallery — scroll left and right to view"
  >
    {
      title && (
        <div class="hseq__intro">
          <a class="hseq__back link-underline" href="/projects">← Work</a>
          <p class="eyebrow">{[category, year].filter(Boolean).join(' · ')}</p>
          <h1>{title}</h1>
          {summary && <p class="hseq__summary">{summary}</p>}
        </div>
      )
    }
    {
      photos.map((p, i) => (
        <figure
          class={`hseq__item hseq__item--${p.size ?? 'large'}${p.pair ? ' hseq__item--pair' : ''}${p.alignV === 'bottom' ? ' hseq__item--align-bottom' : ''}${p.space === 'extra-wide' && !p.pair ? ' hseq__item--extra-wide' : ''}${p.space === 'wide' && !p.pair ? ' hseq__item--wide' : ''}`}
          style={p.offsetY ? `--offset-y: ${p.offsetY}` : undefined}
        >
          <img
            src={p.src}
            alt={p.alt}
            loading={i === 0 ? 'eager' : 'lazy'}
            decoding="async"
          />
          {p.caption && <figcaption>{p.caption}</figcaption>}
        </figure>
      ))
    }
    <span class="hseq__tail" aria-hidden="true"></span>
  </div>
  <div class="hseq__hint" aria-hidden="true">scroll →</div>
</section>

<style>
  /* Break out of the content offset so the gallery fills the whole screen,
     letting the (transparent) menu overlay its left edge. */
  .hseq {
    position: relative;
    width: 100vw;
    margin-left: calc(-1 * var(--sidebar-w));
  }

  /* The horizontal scroll track — a row of images, full viewport height.
     Spacing is applied as a per-item left margin (instead of `gap`) so that
     diptych pairs can sit closer together than the normal rhythm. */
  .hseq__track {
    --seq-gap: clamp(2rem, 5vw, 6rem);
    --seq-gap-wide: clamp(3.5rem, 9vw, 10rem);
    --seq-gap-extra-wide: clamp(6rem, 14vw, 16rem);
    --seq-gap-tight: clamp(0.4rem, 0.9vw, 0.85rem);
    display: flex;
    align-items: center;
    height: 100vh;
    overflow-x: auto;
    overflow-y: hidden;
    padding-inline: clamp(1.5rem, 4vw, 4rem);
    scroll-behavior: smooth;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    /* Hide scrollbar but keep scrollability. */
    scrollbar-width: none;
    -ms-overflow-style: none;
    outline: none;
  }
  .hseq__track::-webkit-scrollbar { display: none; }

  /* The title/description rides in the sequence like a first "panel". */
  .hseq__intro {
    flex: 0 0 auto;
    align-self: stretch;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: min(46rem, 86vw);
    /* Clear the overlay menu on the left. */
    padding-left: calc(var(--sidebar-w) + clamp(0.5rem, 1.5vw, 1.5rem));
    padding-right: clamp(2rem, 4vw, 4rem);
  }
  .hseq__back { font-size: 0.8rem; color: var(--ink-soft); margin-bottom: 1.75rem; }
  .hseq__intro h1 {
    font-size: clamp(2.4rem, 5vw, 4.25rem);
    margin-top: 0.6rem;
  }
  .hseq__summary {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2vw, 1.9rem);
    line-height: 1.3;
    color: var(--ink-soft);
    max-width: 32ch;
    margin-top: 1.4rem;
  }

  .hseq__item {
    margin: 0 0 0 var(--seq-gap);
    flex: 0 0 auto;
    align-self: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
    transform: translateY(var(--offset-y, 0));
  }

  /* Bottom-align within the track (e.g. diptych pairs of different heights). */
  .hseq__item--align-bottom { align-self: flex-end; }

  /* A paced pause — noticeably more air before this panel. */
  .hseq__item--wide { margin-left: var(--seq-gap-wide); }

  /* A longer breath — transitions between major sequence movements. */
  .hseq__item--extra-wide { margin-left: var(--seq-gap-extra-wide); }

  /* A diptych: pull this image tight against the previous one. */
  .hseq__item--pair { margin-left: var(--seq-gap-tight); }

  /* No leading margin before the very first panel in the track. */
  .hseq__track > :first-child { margin-left: 0; }

  /* Height is the consistent dimension; width follows natural aspect ratio.
     `size` is reinterpreted as relative HEIGHT/scale to create rhythm. */
  .hseq__item img {
    height: var(--h, 72vh);
    width: auto;
    max-width: none;
    background: var(--bg-soft);
    object-fit: cover;
  }

  .hseq__item--full   { --h: 100vh; }
  .hseq__item--large  { --h: 86vh; }
  .hseq__item--medium { --h: 70vh; }
  .hseq__item--small-plus { --h: 63vh; }
  .hseq__item--small  { --h: 56vh; }
  .hseq__item--xsmall { --h: 44vh; }

  .hseq__item figcaption {
    margin-top: 0.9rem;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-soft);
    max-width: 32ch;
  }

  /* A little breathing room at the end of the track. */
  .hseq__tail {
    flex: 0 0 clamp(1.5rem, 4vw, 4rem);
    height: 1px;
  }

  /* Subtle hint that the row scrolls sideways. */
  .hseq__hint {
    position: absolute;
    right: clamp(1.5rem, 4vw, 4rem);
    bottom: 0.5rem;
    font-size: 0.68rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--ink-soft);
    pointer-events: none;
    animation: hseq-nudge 2.4s var(--ease) infinite;
  }

  @keyframes hseq-nudge {
    0%, 100% { transform: translateX(0); opacity: 0.55; }
    50% { transform: translateX(6px); opacity: 1; }
  }

  /* On mobile the sidebar is a top bar, so don't break out of the layout. */
  @media (max-width: 880px) {
    .hseq { width: 100%; margin-left: 0; }
    .hseq__intro {
      width: 86vw;
      padding-left: clamp(1.25rem, 5vw, 2rem);
      padding-right: clamp(1.25rem, 5vw, 2rem);
    }
  }

  @media (max-width: 720px) {
    .hseq__track { height: 74vh; --seq-gap: clamp(1.5rem, 7vw, 3rem); --seq-gap-wide: clamp(2.5rem, 12vw, 5.5rem); --seq-gap-extra-wide: clamp(4rem, 18vw, 9rem); }
    .hseq__item--full   { --h: 66vh; }
    .hseq__item--large  { --h: 58vh; }
    .hseq__item--medium { --h: 50vh; }
    .hseq__item--small-plus { --h: 45vh; }
    .hseq__item--small  { --h: 40vh; }
    .hseq__item--xsmall { --h: 32vh; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hseq__track { scroll-behavior: auto; }
    .hseq__hint { animation: none; }
  }
</style>

<script>
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const tracks = document.querySelectorAll<HTMLElement>('.hseq__track');

  tracks.forEach((track) => {
    // Translate predominantly-vertical wheel into horizontal scroll, but don't
    // trap the page scroll: when at either end, let the wheel bubble normally.
    track.addEventListener(
      'wheel',
      (e: WheelEvent) => {
        if (Math.abs(e.deltaY) <= Math.abs(e.deltaX)) return; // native horizontal
        const atStart = track.scrollLeft <= 0;
        const atEnd =
          Math.ceil(track.scrollLeft + track.clientWidth) >= track.scrollWidth;
        if ((e.deltaY < 0 && atStart) || (e.deltaY > 0 && atEnd)) return;
        e.preventDefault();
        track.scrollLeft += e.deltaY;
      },
      { passive: false }
    );

    // Keyboard support when the track is focused.
    track.addEventListener('keydown', (e: KeyboardEvent) => {
      const step = track.clientWidth * 0.8;
      const behavior: ScrollBehavior = reduce ? 'auto' : 'smooth';
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        track.scrollBy({ left: step, behavior });
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        track.scrollBy({ left: -step, behavior });
      }
    });
  });
</script>

---
import Layout from '../layouts/Layout.astro';
import { experience, tools } from '../data/experience';
import { site } from '../data/site';
---

<Layout title="Experience" description="Exhibitions, work, and the path so far.">
  <section class="section container">
    <div class="head">
      <p class="eyebrow reveal">The path so far</p>
      <h1 class="reveal">Experience</h1>
    </div>

    <ol class="timeline">
      {
        experience.map((item, i) => (
          <li class="timeline__item reveal" style={`transition-delay:${i * 70}ms`}>
            <div class="timeline__period">{item.period}</div>
            <div class="timeline__content">
              <h2>{item.title}</h2>
              <p class="timeline__org">{item.org}</p>
              <p class="timeline__desc">{item.description}</p>
            </div>
          </li>
        ))
      }
    </ol>

    {
      tools && tools.length > 0 && (
        <div class="tools reveal">
          <p class="eyebrow">Tools & approach</p>
          <ul>
            {tools.map((t) => <li>{t}</li>)}
          </ul>
        </div>
      )
    }

    <p class="reveal" style="margin-top:3rem;">
      <a class="btn" href={`mailto:${site.email}`}>Let's work together</a>
    </p>
  </section>
</Layout>

<style>
  .head { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .head h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); margin-top: 0.75rem; }

  .timeline { list-style: none; margin: 0; padding: 0; }
  .timeline__item {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: clamp(1.5rem, 4vw, 2.25rem);
    border-top: 1px solid var(--line);
  }
  .timeline__item:last-child { border-bottom: 1px solid var(--line); }
  .timeline__period {
    font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--ink-soft);
    padding-top: 0.4rem;
  }
  .timeline__content h2 { font-size: clamp(1.5rem, 3.5vw, 2.1rem); }
  .timeline__org { color: var(--ink); margin: 0.25rem 0 0.5rem; font-weight: 500; }
  .timeline__desc { color: var(--ink-soft); max-width: 56ch; margin: 0; }

  .tools { margin-top: clamp(3rem, 7vw, 5rem); }
  .tools ul {
    display: flex; flex-wrap: wrap; gap: 0.6rem; list-style: none; padding: 0; margin: 1rem 0 0;
  }
  .tools li {
    border: 1px solid var(--line); border-radius: 999px;
    padding: 0.5rem 1.1rem; font-size: 0.85rem; color: var(--ink-soft);
  }

  @media (max-width: 640px) {
    .timeline__item { grid-template-columns: 1fr; gap: 0.5rem; }
  }
</style>

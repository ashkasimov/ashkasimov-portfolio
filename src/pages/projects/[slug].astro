---
import Layout from '../../layouts/Layout.astro';
import Sequence from '../../components/Sequence.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const idx = projects.findIndex((p) => p.slug === project.slug);
const next = projects[(idx + 1) % projects.length];
---

<Layout title={project.title} description={project.summary}>
  <article class="project">
    <div class="container project-top">
      <a class="back link-underline" href="/projects">← All projects</a>

      <header class="project-head">
        <p class="eyebrow reveal">{project.category} · {project.year}</p>
        <h1 class="reveal">{project.title}</h1>
        <p class="lead reveal" style="margin-top:1.25rem;">{project.summary}</p>
      </header>
    </div>

    <Sequence photos={project.photos} />

    {
      next && next.slug !== project.slug && (
        <div class="container">
          <a class="next-project reveal" href={`/projects/${next.slug}`}>
            <span class="eyebrow">Next project</span>
            <span class="next-project__title">{next.title} →</span>
          </a>
        </div>
      )
    }
  </article>
</Layout>

<style>
  .project { padding-block: clamp(3rem, 8vw, 6.5rem); }
  .project-top { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .back { display: inline-block; font-size: 0.85rem; color: var(--ink-soft); margin-bottom: 2rem; }
  .project-head { max-width: 720px; }
  .project-head h1 { font-size: clamp(2.6rem, 8vw, 5rem); margin-top: 0.75rem; }

  .next-project {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: clamp(3rem, 8vw, 6rem);
    padding-top: 2rem;
    border-top: 1px solid var(--line);
  }
  .next-project__title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3.5rem);
    transition: transform 0.4s var(--ease);
  }
  .next-project:hover .next-project__title { transform: translateX(8px); }
</style>

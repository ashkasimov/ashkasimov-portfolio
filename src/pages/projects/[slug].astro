---
import Layout from '../../layouts/Layout.astro';
import Sequence from '../../components/Sequence.astro';
import { projects } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout title={project.title} description={project.summary}>
  <article class="project">
    <div class="container project-top">
      <a class="back link-underline" href="/projects">← All projects</a>

      <header class="project-head">
        <p class="eyebrow reveal">{project.category} · {project.year}</p>
        <h1 class="reveal">{project.title}</h1>
        <p class="lead reveal" style="margin-top:1.25rem;">{project.summary}</p>
      </header>
    </div>

    <Sequence photos={project.photos} />
  </article>
</Layout>

<style>
  .project { padding-block: clamp(2.5rem, 6vw, 4.5rem); }
  .project-top { margin-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .back { display: inline-block; font-size: 0.85rem; color: var(--ink-soft); margin-bottom: 2rem; }
  .project-head { max-width: 720px; }
  .project-head h1 { font-size: clamp(2.6rem, 8vw, 5rem); margin-top: 0.75rem; }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
---

<Layout title="Work" description="Selected photography projects and galleries.">
  <section class="section container">
    <div class="head">
      <p class="eyebrow reveal">Selected Work</p>
      <h1 class="reveal">Projects</h1>
    </div>

    <div class="project-list">
      {
        projects.map((p, i) => (
          <a class="project-row reveal" href={`/projects/${p.slug}`} style={`transition-delay:${i * 70}ms`}>
            <div class="project-row__img">
              <img src={p.cover} alt={`${p.title} — cover`} loading="lazy" decoding="async" />
            </div>
            <div class="project-row__info">
              <h2>{p.title}</h2>
              <p class="project-row__summary">{p.summary}</p>
              <span class="project-row__meta">{p.category} · {p.year} · {p.photos.length} photographs</span>
            </div>
            <span class="project-row__arrow" aria-hidden="true">→</span>
          </a>
        ))
      }
    </div>
  </section>
</Layout>

<style>
  .head { margin-bottom: clamp(2rem, 5vw, 3.5rem); }
  .head h1 { font-size: clamp(2.5rem, 7vw, 4.5rem); margin-top: 0.75rem; }

  .project-list { display: flex; flex-direction: column; }
  .project-row {
    display: grid;
    grid-template-columns: 140px 1fr auto;
    gap: clamp(1.25rem, 4vw, 3rem);
    align-items: center;
    padding-block: clamp(1.25rem, 3vw, 2rem);
    border-top: 1px solid var(--line);
  }
  .project-row:last-child { border-bottom: 1px solid var(--line); }

  .project-row__img { overflow: hidden; aspect-ratio: 4 / 5; background: var(--bg-soft); }
  .project-row__img img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 1s var(--ease);
  }
  .project-row:hover .project-row__img img { transform: scale(1.05); }

  .project-row__info h2 { font-size: clamp(1.6rem, 4vw, 2.5rem); }
  .project-row__summary { color: var(--ink-soft); max-width: 50ch; margin: 0.5rem 0 0.75rem; }
  .project-row__meta {
    font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ink-soft);
  }
  .project-row__arrow { font-size: 1.5rem; color: var(--ink-soft); transition: transform 0.4s var(--ease); }
  .project-row:hover .project-row__arrow { transform: translateX(6px); color: var(--ink); }

  @media (max-width: 640px) {
    .project-row { grid-template-columns: 90px 1fr; }
    .project-row__arrow { display: none; }
  }
</style>
